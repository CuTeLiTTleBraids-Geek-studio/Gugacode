package main

import (
	"fmt"
	"log"
	"net/http"
	"os"
)

// main is the entry point of the generated {{.ProjectName}} HTTP server.
// It starts a minimal server on the port from PORT env var (default 8080).
func main() {
	port := os.Getenv("PORT")
	if port == "" {
		port = "8080"
	}

	mux := http.NewServeMux()
	mux.HandleFunc("/", func(w http.ResponseWriter, r *http.Request) {
		fmt.Fprintf(w, "{{.ProjectName}} is running\n")
	})
	mux.HandleFunc("/health", func(w http.ResponseWriter, r *http.Request) {
		w.WriteHeader(http.StatusOK)
		_, _ = w.Write([]byte("ok\n"))
	})

	addr := ":" + port
	log.Printf("{{.ProjectName}} listening on %s", addr)
	if err := http.ListenAndServe(addr, mux); err != nil {
		log.Fatalf("server error: %v", err)
	}
}
