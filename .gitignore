# ============================================
# 本地/内部草稿（公开文档放在 docs/ 与 .github/）
# Local drafts only — public docs live in docs/ and .github/
# ============================================

# 旧版内部设计稿文件名（勿提交）
DESIGN-*.md
**/superpowers/
docs/prompts/
docs/superpowers/

# ============================================
# 构建产物 / Build artifacts
# ============================================

# Go 二进制 / 安装包（仅根目录可执行文件名，避免误伤源码目录）
bin/
*.exe
*.exe~
*.run
*.dll
*.so
*.dylib
/gugacode
/gugacode.exe
/gugacode.app
/gugacode-console
/gugacode-console.exe
gugacode-server*
/miaomiaocode
/miaomiaocode.exe
/nknk-coding
/nknk-coding.exe

# Windows 资源文件（构建时生成）/ Windows syso (generated)
*.syso
wails_windows_*.syso

# 前端构建产物 / Frontend build output
frontend/dist/

# Wails 绑定：项目服务绑定由 dev/build 时生成，勿提交
# （框架侧 bindings/github.com/wailsapp 等仍跟踪）
frontend/bindings/gugacode/
frontend/.bindings-tmp*

# Vite / TS 缓存
.vite/
frontend/.vite/
*.tsbuildinfo

# 移动平台生成文件（含机器特定路径）/ Mobile generated
build/ios/xcode/overlay.json
build/ios/xcode/gen/
build/android/overlay.json
build/android/gen/
build/android/.gradle/
build/android/**/build/
build/android/local.properties

# Linux AppImage 构建目录
build/linux/appimage/build

# Windows NSIS WebView2 安装包
build/windows/nsis/MicrosoftEdgeWebview2Setup.exe

# Taskfile 缓存 / Taskfile cache
.task/

# 启动日志（本机调试残留）
startup-err.txt
startup-out.txt
bin/startup-err.txt
bin/startup-out.txt

