    "@vueuse/core": "^14.3.0",
    "@wailsio/runtime": "3.0.0-alpha.95",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "animate.css": "^4.1.1",
    "dompurify": "^3.4.11",
    "element-plus": "^2.14.2",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "monaco-editor": "^0.55.1",
    "tailwindcss": "^4.3.2",
    "vue": "^3.2.45",
    "vue-router": "^5.1.0"
  },
